# Скопировать на VPS, подправить пути при другом домене:
#   sudo cp nginx-slapshous.conf.example /etc/nginx/sites-available/slapshous
#   sudo ln -sf /etc/nginx/sites-available/slapshous /etc/nginx/sites-enabled/
#   sudo rm -f /etc/nginx/sites-enabled/default   # если мешает default_server
#   sudo nginx -t && sudo systemctl reload nginx
# TLS:
#   sudo certbot --nginx -d slapshous.ru -d www.slapshous.ru
#
# Docker: фронт слушает 127.0.0.1:5173, внутри контейнера nginx проксирует /api → backend.

server {
    listen 80;
    listen [::]:80;
    server_name slapshous.ru www.slapshous.ru;

    client_max_body_size 200M;

    location / {
        proxy_pass http://127.0.0.1:5173;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 300s;
    }
}
