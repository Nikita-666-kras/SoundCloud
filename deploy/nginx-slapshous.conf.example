# Скопируй на VPS в /etc/nginx/sites-available/slapshous.ru
# sudo ln -s /etc/nginx/sites-available/slapshous.ru /etc/nginx/sites-enabled/
# sudo nginx -t && sudo systemctl reload nginx
# sudo certbot --nginx -d slapshous.ru -d www.slapshous.ru
#
# Docker: фронт слушает 127.0.0.1:5173 (см. docker-compose.yml)

server {
    listen 80;
    listen [::]:80;
    server_name slapshous.ru www.slapshous.ru;

    location / {
        proxy_pass http://127.0.0.1:5173;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }
}
