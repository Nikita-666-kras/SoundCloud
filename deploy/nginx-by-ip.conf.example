# Временно открыть сайт по IP без домена (только HTTP, для проверки).
# После появления домена — перейти на nginx-slapshous.conf.example + certbot.
#
#   sudo cp nginx-by-ip.conf.example /etc/nginx/sites-available/soundcloud-ip
#   sudo ln -sf /etc/nginx/sites-available/soundcloud-ip /etc/nginx/sites-enabled/
#   sudo nginx -t && sudo systemctl reload nginx
#   sudo ufw allow 80/tcp

server {
    listen 80 default_server;
    listen [::]:80 default_server;
    server_name _;

    client_max_body_size 200M;

    location / {
        proxy_pass http://127.0.0.1:5173;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 300s;
    }
}
